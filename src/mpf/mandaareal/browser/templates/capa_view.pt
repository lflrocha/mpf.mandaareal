              <div class="card-noticia">
                <div class="imagem-noticia">
                  <a href="noticias/mpf-participa-da-semana-de-educacao-midiatica-com-o-projeto-201cmanda-a-real201d.html"
                    tal:attributes="href python:item['url']">
                    <img src="noticias/mpf-participa-da-semana-de-educacao-midiatica-com-o-projeto-201cmanda-a-real201d/@@images/image/mini" alt="Logo do projeto Manda a Real" title="Logo do projeto Manda a Real"
                      tal:attributes="src python:item['image'];
