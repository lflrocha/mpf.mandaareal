<html xmlns:metal="http://xml.zope.org/namespaces/metal" xmlns:tal="http://xml.zope.org/namespaces/tal">

<body metal:use-macro="here/main_template/macros/master">


  <metal:styles fill-slot="style_slot">

    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <meta charset="utf-8">

    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js" integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl" crossorigin="anonymous"></script>

    <style type="text/css">
      @media (max-width: 767px) {
        #globalnav-wrapper {
          font-size: 70% !important;
        }
      }

      body #visual-portal-wrapper #portal-columns {
        background-color: #ffffff !important;
        font-family: 'Inter', sans-serif !important;
      }

      h1 {
        color: #5f2f7e;
        margin-bottom: 2rem;
        margin-left: 2rem !important;
        font-size: 2rem;
        font-weight: 900;
      }


      .card {
        max-width: 1000px !important;
        margin: 0 auto !important;
        border: 0 !important;
      }

      #accordion .card .card-header {
        background-color: #5f2f7e;
        padding: 0;
      }

      #accordion .card .card-header .btn-link {
        color: white !important;
        font-size: 22px;
        text-align: left;
        text-decoration: none;
        padding: 0.5rem 1rem;
        width: 97%;
        font-weight: bold !important;
      }

      #accordion .card .card-header .btn-link:hover {
        color: white !important;
        text-decoration: none;
        background-color: #39174f5c;
        cursor: pointer;
      }

      #accordion .card .card-header a:before {
        content: url(imagens/setinha-accordion.png);
        scale: 0.6;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        flex-shrink: 0;
      }

      .card-body {
        background-color: #f3f3f3 !important;
        font-size: 20px !important;
        color: #602f7e !important;
      }

      .collapse .card-body p {
        font-size: 20px !important;
        color: #602f7e !important;
      }

      .collapsing .card-body p {
        font-size: 20px !important;
        color: #602f7e !important;
        animation: myAnim 0.1s ease;
      }

      .collapse.show {
        opacity: 1 !important;
      }

      #content-core #parent-fieldname-text p {
        margin-left: 1.5rem !important;
      }

      @keyframes myAnim {
        0% {
          opacity: 0;
        }

        100% {
          opacity: 1;
        }
      }

      .in {
        display: block !important;
      }

      a {
        border-bottom: 1px solid rgba(0, 0, 0, 0.125) !important;
      }

    </style>




  </metal:styles>





  <metal:main fill-slot="main">


        <div id="parent-fieldname-text" class="plain">
          <div id="content-core">

          <h1>
            Me explica, MPF!
          </h1>


          <div class="conteudo_FAQ">



            <div id="resultado_busca">


              <div id="accordion">

                <div class="card">

                  <div>





                    <tal:def define="itens view/meexplica">
                      <tal:rep repeat="item itens">
                        <div class="card-header" id="acordeon-acesso-a-informacao"
                          tal:attributes="id string:acordeon-${item/id};">
                          <a class="btn btn-link" data-toggle="collapse" data-target="#collapse-acesso-a-informacao" aria-expanded="true" aria-controls="collapse-acordeon01" data-controls="collapse-acesso-a-informacao"
                            tal:attributes="data-target string:#collapse-${item/id};
                                            aria-controls string:collapse-acordeon${item/contador};
                                            data-controls string:collapse-${item/id}"
                            tal:content="python:item['title']">
                          </a>
                        </div>
                        <div id="collapse-acesso-a-informacao" class="collapse" aria-labelledby="acordeon-acesso-a-informacao" data-parent="#accordion"
                          tal:attributes="id string:collapse-${item/id};
                                          aria-labelledby string:acordeon-${item/id}">
                          <div class="card-body"
                            tal:content="structure python:item['text']">

                          </div>
                        </div>
                      </tal:rep>
                    </tal:def>

                  </div>

                </div>


              </div>

          </div>

        </div>

      </div>

    </div>


  </metal:main>
</body>

</html>
